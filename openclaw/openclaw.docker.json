{
  "agents": {
    "defaults": {
      "workspace": "/secretary/workspace",
      "model": {
        "primary": "openai-codex/gpt-5.4"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "0.0.0.0"
  },
  "mcp": {
    "servers": {
      "morning-briefing": {
        "transport": "stdio",
        "command": "node",
        "args": [
          "/secretary/src/mcp-server.js"
        ],
        "cwd": "/secretary"
      }
    }
  }
}
